local function UpdateXP(amount)
	Data.XP += amount

	local needed = Data.Level * 100

	if Data.XP >= needed then
		Data.XP -= needed
		Data.Level += 1
		Notify("LEVEL UP: "..Data.Level)
	end

	XPLabel.Text = "Level: "..Data.Level

	XPBar:TweenSize(
		UDim2.new(Data.XP / needed,0,1,0),
		Enum.EasingDirection.Out,
		Enum.EasingStyle.Quad,
		0.25,
		true
	)
end

