local function FadeFrame(frame, state)
	local goal = {}

	if state == "in" then
		frame.BackgroundTransparency = 1
		goal.BackgroundTransparency = 0
	else
		goal.BackgroundTransparency = 1
	end

	TweenService:Create(frame, TweenInfo.new(0.25), goal):Play()
end

