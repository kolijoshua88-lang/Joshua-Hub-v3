local function AIAdvanced(msg)
	msg = msg:lower()

	local responses = {}

	if msg:find("hello") then
		table.insert(responses, "Hello! Joshua AI online.")
	end

	if msg:find("create") then
		table.insert(responses, "Generated Feature: Smart UI Module System")
		table.insert(responses, "Suggestion: Add animated sidebar blur effect")
	end

	if msg:find("help") then
		table.insert(responses, "Commands: xp, coins, theme, create")
	end

	if msg:find("xp") then
		UpdateXP(20)
		table.insert(responses, "XP +20 awarded")
	end

	if #responses == 0 then
		return "AI: Try 'create' or 'xp' or 'help'"
	end

	return table.concat(responses, "\n")
end

